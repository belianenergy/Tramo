/* Tramo — Clean B2B Visual System
 * White canvas + charcoal data + single green accent
 * ReflexAI/Linear-inspired editorial-industrial
 */

/* Font loading — DM Sans (display) + JetBrains Mono (data) */
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=JetBrains+Mono:wght@100..800&display=swap');

@import "tailwindcss";
@import "shadcn/tailwind.css";

:root {
  /* ── Core Palette ── */

  /* Primary — single green accent */
  --color-primary:       #0F7B5A;
  --color-primary-hover: #0C6348;
  --color-primary-active:#0A5238;
  --color-primary-subtle: #EBF5F0;

  /* Surfaces */
  --color-bg:            #FAFAFA;   /* page background — clean white */
  --color-white:         #FFFFFF;   /* card surface */

  /* Text */
  --color-dark:          #1A1A2E;   /* headlines, body */
  --color-gray:          #4B5563;   /* secondary text — AA-safe */
  --color-gray-light:    #6B7280;   /* tertiary text — improved contrast */

  /* Borders */
  --color-border:        #E5E7EB;   /* main border */
  --color-border-light:  #F3F4F6;   /* subtle border */

  /* ── Status colors ── */
  --color-status-success:        oklch(58% 0.16 155);
  --color-status-success-bright: oklch(72% 0.18 150);
  --color-status-warning:        oklch(52% 0.13 64);
  --color-status-warning-bright: oklch(76% 0.16 70);
  --color-status-danger:         oklch(58% 0.22 29);
  --color-status-info:           oklch(58% 0.16 260);
  --color-status-teal:           oklch(66% 0.13 190);
  --color-status-teal-dark:      oklch(55% 0.12 185);

  --color-status-warning-soft:   oklch(95% 0.020 85);
  --color-status-warning-border: oklch(85% 0.040 80);
  --color-status-danger-soft:    oklch(95% 0.025 25);
  --color-status-danger-border:  oklch(85% 0.050 25);
  --color-status-success-soft:   oklch(95% 0.020 145);
  --color-status-success-border: oklch(85% 0.040 145);
  --color-status-info-soft:      oklch(95% 0.020 250);
  --color-status-info-border:    oklch(85% 0.040 250);
  --color-data-grid:             oklch(88% 0.005 30);
  --color-data-tick:             oklch(55% 0.005 30);

  --color-status-danger-bg:      oklch(95% 0.025 25);
  --color-status-danger-border:  oklch(85% 0.050 25);
  --color-status-warning-bg:     oklch(95% 0.020 85);
  --color-status-warning-border: oklch(85% 0.040 80);
  --color-status-success-bg:     oklch(95% 0.020 145);
  --color-status-success-border: oklch(85% 0.040 145);
  --color-status-info-bg:        oklch(95% 0.020 250);
  --color-status-info-border:    oklch(85% 0.040 250);
  --color-chart-grid:            oklch(88% 0.005 172);
  --color-chart-tick:            oklch(55% 0.018 172);
  --color-og-grid:               oklch(99% 0.006 125 / 0.03);

  /* ── Legacy aliases for dashboard/app compatibility ── */
  --color-canopy:               var(--color-primary);
  --color-canopy-hover:         var(--color-primary-hover);
  --color-canopy-active:        var(--color-primary-active);
  --color-canopy-disabled:      oklch(57% 0.035 172);
  --color-canopy-subtle:        var(--color-primary-subtle);
  --color-canopy-border:        oklch(65% 0.045 165);
  --color-mint-pulse:           var(--color-primary);
  --color-mint-dark:            var(--color-primary);
  --color-orb-violet:           var(--color-primary);
  --color-cream-paper:          var(--color-bg);
  --color-sheet-white:          var(--color-white);
  --color-bark:                 var(--color-dark);
  --color-ink:                  var(--color-dark);
  --color-slate:                var(--color-gray);
  --color-charcoal:             var(--color-dark);
  --color-sage-mist:            var(--color-border);
  --color-pale-sage:            var(--color-bg);
  --color-muted-slate:          var(--color-gray-light);
  --color-paper:                var(--color-bg);
  --color-paper-2:              var(--color-white);
  --color-rule:                 var(--color-border);
  --color-surface:              var(--color-bg);
  --color-muted:                var(--color-gray);
  --color-soft:                 var(--color-gray);
  --color-ink-2:                var(--color-gray);
  --color-data-muted:           var(--color-gray-light);
  --color-border:               var(--color-border);
  --color-border-strong:        var(--color-border);
  --color-surface-alt:          var(--color-white);
  --color-rose:                 var(--color-primary);
  --color-crimson:              var(--color-primary);
  --color-amber:                var(--color-primary);
  --color-amber-accessible:     var(--color-primary);
  --color-blue:                 var(--color-gray);
  --color-accent:               var(--color-primary);
  --color-accent-soft:          var(--color-primary-subtle);
  --color-accent-ink:           var(--color-white);
  --color-lime:                 var(--color-primary);

  /* Backward-compatible aliases */
  --ink:              var(--color-dark);
  --snow:             var(--color-bg);
  --canvas:           var(--color-bg);
  --fog:              var(--color-white);
  --pebble:           var(--color-border);
  --graphite:         var(--color-gray);
  --slate:            var(--color-gray);
  --steel:            var(--color-gray-light);
  --text-primary:     var(--color-dark);
  --text-secondary:   var(--color-gray);
  --primary:          var(--color-primary);

  /* Focus ring */
  --color-focus:        var(--color-primary);
  --color-focus-on-dark: var(--color-white);

  /* Gradients */
  --gradient-hero-wash: linear-gradient(180deg, #FAFAFA 0%, #FFFFFF 100%);
  --gradient-isometric: linear-gradient(180deg, #FAFAFA 0%, #FFFFFF 100%);

  /* ── Typography ── */
  --font-display: "DM Sans", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  --font-body:    system-ui, "Segoe UI", "Aptos", sans-serif;
  --font-mono:    "JetBrains Mono", "Cascadia Mono", ui-monospace, monospace;

  /* ── Spacing ── */
  --space-3xs: 0.5rem;
  --space-2xs: 1rem;
  --space-xs:  1.5rem;
  --space-sm:  2rem;
  --space-md:  2.5rem;
  --space-lg:  3rem;
  --space-xl:  4rem;
  --space-2xl: 5.5rem;
  --space-3xl: 7.5rem;

  /* ── Type scale ── */
  --text-xs:       0.8125rem;
  --text-sm:       0.875rem;
  --text-base:     1rem;
  --text-md:       1.125rem;
  --text-lg:       1.25rem;
  --text-xl:       1.5rem;
  --text-2xl:      2.25rem;
  --text-3xl:      3rem;
  --text-4xl:      3.75rem;
  --text-display:  clamp(2.75rem, 5vw + 1rem, 4.75rem);
  --text-display-s: clamp(2rem, 4vw + 0.5rem, 3.25rem);

  /* ── Motion ── */
  --ease-out:    cubic-bezier(0.16, 1, 0.3, 1);
  --ease-in:     cubic-bezier(0.7,  0, 0.84, 0);
  --ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  --dur-micro:   120ms;
  --dur-short:   220ms;
  --dur-long:    420ms;

  /* ── Radii ── */
  --radius-sm:    4px;
  --radius-md:    8px;
  --radius-lg:    16px;
  --radius-pill:  9999px;

  /* Shadows */
  --shadow-sm:  none;
  --shadow-md:  none;
  --shadow-lg:  none;
  --shadow-pill: none;

  /* Page max */
  --page-max: 1200px;
}

/* ── shadcn/ui theme mapping ── */
@theme inline {
  --color-background:          var(--color-bg);
  --color-foreground:          var(--color-dark);
  --font-sans:                 var(--font-body);
  --font-mono:                 var(--font-mono);
  --color-card:                var(--color-white);
  --color-card-foreground:     var(--color-dark);
  --color-popover:             var(--color-white);
  --color-popover-foreground:  var(--color-dark);
  --color-primary:             var(--color-primary);
  --color-primary-foreground:  var(--color-white);
  --color-secondary:           var(--color-border);
  --color-secondary-foreground: var(--color-dark);
  --color-muted:               var(--color-border);
  --color-muted-foreground:    var(--color-gray-light);
  --color-accent-shadcn:       var(--color-white);
  --color-accent-foreground:   var(--color-dark);
  --color-destructive:         oklch(55% 0.22 28);
  --color-destructive-foreground: var(--color-white);
  --color-border:              var(--color-border);
  --color-input:               var(--color-bg);
  --color-ring:                var(--color-focus);
  --radius-sm:                 4px;
  --radius-md:                 8px;
  --radius-lg:                 16px;
  --radius-xl:                 16px;
}

/* ── Base ── */
* { border-color: transparent; }

html, body {
  overflow-x: clip;
}

body {
  background: var(--color-bg);
  color: var(--color-dark);
  font-family: var(--font-body);
  -webkit-font-smoothing: antialiased;
  font-size: var(--text-base);
  line-height: 1.6;
}

html { scroll-behavior: smooth; }

/* ── Focus ring ── */
a:focus-visible,
button:focus-visible,
input:focus-visible,
select:focus-visible,
textarea:focus-visible,
[tabindex]:focus-visible {
  outline: 2.5px solid var(--color-focus);
  outline-offset: 2px;
  transition: none !important;
}
a:focus:not(:focus-visible),
button:focus:not(:focus-visible),
input:focus:not(:focus-visible),
select:focus:not(:focus-visible),
textarea:focus:not(:focus-visible) {
  outline: none;
}

/* ── Skip-to-content ── */
.skip-link {
  position: absolute;
  top: -100%;
  left: 1rem;
  z-index: 100;
  padding: 0.75rem 1.25rem;
  border-radius: var(--radius-sm);
  background: var(--color-primary);
  color: var(--color-white);
  font-size: var(--text-sm);
  font-weight: 500;
  transition: transform var(--dur-short) var(--ease-out);
}
.skip-link:focus {
  top: 1rem;
}

.overflow-x-auto {
  max-width: 100%;
  -webkit-overflow-scrolling: touch;
}

.chart-bar {
  min-width: 3px;
}

/* ── Utility helpers ── */
.font-display  { font-family: var(--font-display); }
.font-mono     { font-family: var(--font-mono); }
.tabular-nums  { font-variant-numeric: tabular-nums; }

/* ── Reduced motion ── */
@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
  }
  [data-animate] { opacity: 1 !important; transform: none !important; }
}
