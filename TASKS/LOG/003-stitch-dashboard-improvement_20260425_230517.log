              <button onClick={exportCSV} className=\"bg-slate-700 hover:bg-slate-600 text-white px-4 py-2 rounded-lg font-medium transition\">📥 CSV</button>
            </div>

            {"'!savings ? (
              <div className="text-center py-12">
                <p className="text-slate-400 mb-4">Selecciona unha propiedade para calcular o aforro.</p>
                <button onClick={() => setActiveTab('"'listings')} className=\"bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-2 rounded-lg\">
                  Ir a Propiedades
                </button>
              </div>
            ) : (
              <div className=\"space-y-6\">
                <div className=\"grid grid-cols-1 md:grid-cols-3 gap-6 print:grid-cols-3\">
                  <MetricCard
                    title=\"Custo Actual\"
                    value={savings.costBefore.toFixed(2)}
                    unit=\"€/mes\"
                    variant=\"danger\"
                    subtitle=\"Sen optimización\"
                  />
                  <MetricCard
                    title=\"Custo Optimizado\"
                    value={savings.costAfter.toFixed(2)}
                    unit=\"€/mes\"
                    variant=\"success\"
                    subtitle=\"Con horarios baixa demanda\"
                  />
                  <MetricCard
                    title=\"Aforro Mensual\"
                    value={savings.savingsMonthly.toFixed(2)}
                    unit=\"€/mes\"
                    variant=\"success\"
                    subtitle={"'`~${savings.savingsYearly.toFixed(2)}€/ano`}
                    trend="down"
                    trendValue="Optimizado"
                  />
                </div>

                <div className="bg-slate-700 rounded-xl p-6 print:break-inside-avoid">
                  <h3 className="font-semibold mb-3">📋 Detalle</h3>
                  <div className="grid grid-cols-2 gap-3 text-sm">
                    <div><span className="text-slate-400">Propiedade:</span> <span className="text-white">{savings.listingName}</span></div>
                    <div><span className="text-slate-400">Localización:</span> <span className="text-white">{savings.location}</span></div>
                    <div><span className="text-slate-400">Consumo:</span> <span className="text-white">{savings.monthlyKwh} kWh/mes</span></div>
                    <div><span className="text-slate-400">Ocupación:</span> <span className="text-white">{(savings.occupancyRate * 100).toFixed(0)}%</span></div>
                    <div><span className="text-slate-400">Tarifa:</span> <span className="text-white">{savings.tariffUsed}</span></div>
                    <div><span className="text-slate-400">Factor ocupación:</span> <span className="text-white">{savings.occupancyRate > 0.8 ? '"'Alta (30%)' : savings.occupancyRate > 0.5 ? 'Media (65%)' : 'Baixa (90%)'}</span></div>
                  </div>
                </div>

                <div className=\"bg-slate-800 rounded-xl p-4 print:hidden\">
                  <h3 className=\"font-semibold mb-2\">💡 Consello</h3>
                  <p className=\"text-slate-300 text-sm\">
                    {savings.occupancyRate > 0.8
                      ? 'Propiedade con alta ocupación. Considera negociar unha tarifa indexada co teu proveedor para beneficiarte das horas de baixa demanda.'
                      : 'Podes programar os termostatos para pre-quentar durante as horas de baixa demanda (00h-08h) e así reducir o custo total.'}
                  </p>
                </div>
              </div>
            )}
          </section>
        </div>
      )}

      <footer className=\"mt-16 pt-8 border-t border-slate-800 text-center text-slate-600 text-sm print:hidden\">
        EnergyOS MVP v0.1 · Next.js + JSON Storage + Tailwind · OpenClaw 🐙
      </footer>
    </main>
  )
}
