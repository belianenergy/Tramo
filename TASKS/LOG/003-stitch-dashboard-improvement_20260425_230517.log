                    onChange={e => setTariffForm({ ...tariffForm, baseRate: parseFloat(e.target.value) || 0 })}
                    className=\"w-full bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-white focus:border-emerald-500 focus:outline-none\"
                  />
                </div>
                <div>
                  <label className=\"block text-slate-400 text-sm mb-1\">Tarifa Pico (€/kWh)</label>
                  <input
                    type=\"number\"
