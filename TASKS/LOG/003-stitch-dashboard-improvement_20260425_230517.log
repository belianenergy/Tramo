'use client'

import { ReactNode } from 'react'

interface MetricCardProps {
  title: string
  value: string | number
  unit?: string
  subtitle?: string
  trend?: 'up' | 'down' | 'neutral'
  trendValue?: string
  icon?: ReactNode
  variant?: 'default' | 'success' | 'warning' | 'danger'
}

export function MetricCard({
  title,
  value,
  unit,
  subtitle,
  trend,
  trendValue,
  icon,
  variant = 'default',
}: MetricCardProps) {
  const variantStyles = {
    default: 'border-slate-700',
    success: 'border-emerald-700 bg-emerald-900/30',
    warning: 'border-amber-700 bg-amber-900/30',
    danger: 'border-red-700 bg-red-900/30',
  }

  const iconStyles = {
    default: 'text-emerald-500',
    success: 'text-emerald-400',
    warning: 'text-amber-400',
    danger: 'text-red-400',
  }

  const valueStyles = {
    default: 'text-white',
    success: 'text-emerald-400',
    warning: 'text-amber-400',
    danger: 'text-red-400',
  }

  const trendIcons = {
    up: '↑',
    down: '↓',
    neutral: '→',
  }

  const trendColors = {
    up: 'text-red-400',
    down: 'text-emerald-400',
    neutral: 'text-slate-400',
  }

  return (
    <div className={"'`bg-slate-800 rounded-xl p-6 border ${variantStyles[variant]} transition-all hover:border-emerald-600`}>
      <div className="flex items-start justify-between mb-4">
        <p className="text-slate-400 text-xs font-medium uppercase tracking-wider">{title}</p>
        {icon && <span className={`text-2xl ${iconStyles[variant]}`}>{icon}</span>}
      </div>
      
      <div className="mb-2">
        <span className={`text-4xl font-bold ${valueStyles[variant]}`}>{value}</span>
        {unit && <span className="text-slate-400 text-lg ml-1">{unit}</span>}
      </div>

      {subtitle && <p className="text-slate-500 text-sm mb-2">{subtitle}</p>}

      {trend && trendValue && (
        <div className={`flex items-center gap-1 text-sm ${trendColors[trend]}`}>
          <span>{trendIcons[trend]}</span>
          <span>{trendValue}</span>
        </div>
      )}
    </div>
  )
}
