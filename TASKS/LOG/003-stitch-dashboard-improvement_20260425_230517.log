          <p className="text-slate-400 text-sm">{location}</p>
        </div>
        <span className={`${config.bg} text-white text-xs font-medium uppercase tracking-wider px-2 py-1 rounded-full`}>
          {config.label}
        </span>
      </div>

      <div className="grid grid-cols-2 gap-4 mb-4">
        <div>
          <p className="text-slate-500 text-xs uppercase tracking-wider mb-1">Consumo</p>
          <p className="text-2xl font-bold text-emerald-400">{monthlyKwh}</p>
          <p className="text-slate-500 text-xs">kWh/mes</p>
        </div>
        <div>
          <p className="text-slate-500 text-xs uppercase tracking-wider mb-1">Ocupación</p>
          <p className="text-2xl font-bold text-white">{Math.round(occupancyRate * 100)}%</p>
          <div className="w-full bg-slate-700 rounded-full h-1.5 mt-1">
            <div 
              className={`h-1.5 rounded-full ${config.bg}`}
              style={{ width: `${occupancyRate * 100}%` }}
            />
          </div>
        </div>
      </div>

      <div className="flex gap-2">
        {onCalculate && (
          <button
            onClick={onCalculate}
            className="flex-1 bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-medium py-2 px-3 rounded-lg transition"
          >
            Calcular Aforro
          </button>
        )}
        {onEdit && (
          <button
            onClick={onEdit}
            className="bg-slate-700 hover:bg-slate-600 text-slate-300 text-sm font-medium py-2 px-3 rounded-lg transition"
          >
            Editar
          </button>
        )}
        {actions}
      </div>
    </div>
  )
}
