'use client'

import { useState, useEffect } from 'react'
import { MetricCard, ConsumptionChart, PropertyCard } from '../components'

interface Listing {
  id: number
  name: string
  location: string
  monthlyKwh: number
  occupancyRate: number
  ownerContact: string
  createdAt: string
}

interface Tariff {
  id: number
  region: string
  provider: string
  baseRate: number
  peakRate: number
  offPeakRate: number
}

interface DashboardData {
  totalListings: number
  totalKwh: number
  totalOccupancy: number
  totalSavingsMonthly: number
  totalSavingsYearly: number
  totalCostBefore: number
  totalCostAfter: number
  tariffsCount: number
  forecastsCount: number
}

interface SavingsResult {
  listingId: number
  listingName: string
  location: string
  monthlyKwh: number
  occupancyRate: number
  costBefore: number
  costAfter: number
  savingsMonthly: number
  savingsYearly: number
  tariffUsed: string
  breakdown: {
    peakHoursKwh: number
    offPeakHoursKwh: number
    baseCostPeak: number
    optimizedCostOffPeak: number
  }
}

export default function Home() {
  const [listings, setListings] = useState<Listing[]>([])
  const [tariffs, setTariffs] = useState<Tariff[]>([])
  const [dashboard, setDashboard] = useState<DashboardData | null>(null)
  const [form, setForm] = useState({ name: '', location: '', monthlyKwh: 0, occupancyRate: 0.7, ownerContact: '' })
  const [tariffForm, setTariffForm] = useState({ region: '', provider: '', baseRate: 0, peakRate: 0, offPeakRate: 0 })
  const [savings, setSavings] = useState<SavingsResult | null>(null)
  const [selectedListing, setSelectedListing] = useState<Listing | null>(null)
  const [loading, setLoading] = useState(false)
  const [activeTab, setActiveTab] = useState<'dashboard' | 'listings' | 'tariffs' | 'results'>('dashboard')

  useEffect(() => {
    fetchData()
  }, [])

  async function fetchData() {
    const [listingsRes, tariffsRes, dashRes] = await Promise.all([
      fetch('/api/listings'),
      fetch('/api/tariffs'),
      fetch('/api/dashboard'),
    ])
    if (listingsRes.ok) setListings(await listingsRes.json())
    if (tariffsRes.ok) setTariffs(await tariffsRes.json())
    if (dashRes.ok) setDashboard(await dashRes.json())
  }

  async function handleSubmitListing(e: React.FormEvent) {
    e.preventDefault()
    setLoading(true)
    const res = await fetch('/api/listings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(form),
    })
    if (res.ok) {
      setForm({ name: '', location: '', monthlyKwh: 0, occupancyRate: 0.7, ownerContact: '' })
      await fetchData()
    }
    setLoading(false)
  }

  async function handleSubmitTariff(e: React.FormEvent) {
    e.preventDefault()
    setLoading(true)
    const res = await fetch('/api/tariffs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(tariffForm),
    })
    if (res.ok) {
      setTariffForm({ region: '', provider: '', baseRate: 0, peakRate: 0, offPeakRate: 0 })
      await fetchData()
    }
    setLoading(false)
  }

  async function calculateSavingsForListing(listingId: number) {
    setLoading(true)
    const res = await fetch('/api/savings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ listingId }),
    })
    if (res.ok) {
      const data = await res.json()
      setSavings(data)
      setActiveTab('results')
    }
    setLoading(false)
  }

  async function exportCSV() {
    const res = await fetch('/api/export/csv', { method: 'POST' })
    if (res.ok) {
      const blob = await res.blob()
      const url = URL.createObjectURL(blob)
      const a = document.createElement('a')
      a.href = url
      a.download = 'energyos-report.csv'
      a.click()
    }
  }

  // Get consumption chart data from listings
  const chartData = listings.slice(0, 7).map((listing, index) => ({
    label: listing.name.substring(0, 8) + '...',
    value: listing.monthlyKwh,
  }))

  // Determine status based on consumption
  const getStatus = (kwh: number, occupancy: number) => {
    const normalized = kwh / (occupancy * 100)
    if (normalized > 80) return 'danger'
    if (normalized > 60) return 'warning'
    return 'success'
  }

  return (
    <main className=\"min-h-screen p-4 md:p-8 max-w-7xl mx-auto print:p-2 print:max-w-none\">
      <header className=\"mb-8 print:mb-2\">
        <h1 className=\"text-3xl md:text-4xl font-bold text-emerald-400\">⚡ EnergyOS</h1>
        <p className=\"text-slate-400 mt-1\">Xestión Enerxética Intelixente para Airbnb</p>
      </header>

      <nav className=\"flex gap-2 md:gap-4 mb-8 border-b border-slate-700 pb-4 print:hidden overflow-x-auto\">
        {([
          ['dashboard', '📊 Dashboard'],
          ['listings', '🏠 Propiedades'],
          ['tariffs', '⚡ Tarifas'],
          ['results', '📈 Resultados'],
        ] as const).map(([key, label]) => (
          <button
            key={key}
            onClick={() => setActiveTab(key)}
            className={"'`px-3 md:px-4 py-2 rounded-lg font-medium transition whitespace-nowrap text-sm md:text-base ${
              activeTab === key
                ? '"'bg-emerald-600 text-white'
                : 'bg-slate-800 text-slate-300 hover:bg-slate-700'
            }"'`}
          >
            {label}
          </button>
        ))}
      </nav>

      {activeTab === '"'dashboard' && (
        <div className=\"space-y-6\">
          {/* Metric Cards Grid */}
          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">
            <MetricCard
              title=\"Total Propiedades\"
              value={dashboard?.totalListings ?? 0}
              icon={<span>🏠</span>}
              subtitle=\"Activas no sistema\"
              trend=\"up\"
              trendValue=\"+2 este mes\"
            />
            <MetricCard
              title=\"Consumo Total\"
              value={(dashboard?.totalKwh ?? 0).toLocaleString()}
              unit=\"kWh\"
              icon={<span>⚡</span>}
              variant=\"success\"
              subtitle=\"Este mes\"
            />
            <MetricCard
              title=\"Aforro Mensual\"
              value={(dashboard?.totalSavingsMonthly ?? 0).toFixed(2)}
              unit=\"€\"
              icon={<span>💰</span>}
              variant=\"success\"
              subtitle=\"Optimización activa\"
              trend=\"down\"
              trendValue=\"-12% vs mes pasado\"
            />
            <MetricCard
              title=\"Ocupación Media\"
              value={Math.round(dashboard?.totalOccupancy ?? 0)}
              unit=\"%\"
              icon={<span>📊</span>}
              subtitle=\"Taxa media ocupación\"
              trend=\"neutral\"
              trendValue=\" estable\"
            />
          </div>

          {/* Consumption Chart */}
          <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">
            <div className=\"lg:col-span-2\">
              <ConsumptionChart data={chartData.length > 0 ? chartData : [
                { label: 'Ene', value: 450 },
                { label: 'Feb', value: 380 },
                { label: 'Mar', value: 520 },
                { label: 'Abr', value: 410 },
                { label: 'Mai', value: 490 },
                { label: 'Xuñ', value: 580 },
                { label: 'Xul', value: 620 },
              ]} height={280} />
            </div>
            
            {/* Quick Stats */}
            <div className=\"bg-slate-800 rounded-xl p-5 border border-slate-700\">
              <h3 className=\"text-lg font-semibold text-white mb-4\">Resumo Rápido</h3>
              <div className=\"space-y-4\">
                <div className=\"flex justify-between items-center py-3 border-b border-slate-700\">
                  <span className=\"text-slate-400\">Custo total antes</span>
                  <span className=\"text-red-400 font-mono\">{(dashboard?.totalCostBefore ?? 0).toFixed(2)}€</span>
                </div>
                <div className=\"flex justify-between items-center py-3 border-b border-slate-700\">
                  <span className=\"text-slate-400\">Custo total despois</span>
                  <span className=\"text-emerald-400 font-mono\">{(dashboard?.totalCostAfter ?? 0).toFixed(2)}€</span>
                </div>
                <div className=\"flex justify-between items-center py-3\">
                  <span className=\"text-emerald-400 font-medium\">Aforro Total Ano</span>
                  <span className=\"text-emerald-300 font-bold text-xl\">{(dashboard?.totalSavingsYearly ?? 0).toFixed(2)}€</span>
                </div>
              </div>
            </div>
          </div>

          {/* Property Cards */}
          <section>
            <h2 className=\"text-xl font-semibold mb-4\">Propiedades</h2>
            <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4\">
              {listings.length === 0 ? (
                <div className=\"col-span-full text-center py-12 bg-slate-800/50 rounded-xl border border-slate-700\">
                  <p className=\"text-slate-400 mb-4\">Non hai propiedades aínda.</p>
                  <button onClick={() => setActiveTab('listings')} className=\"bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-2 rounded-lg\">
                    Engadir Primeira Propiedade
                  </button>
                </div>
              ) : (
                listings.map(listing => (
                  <PropertyCard
                    key={listing.id}
                    name={listing.name}
                    location={listing.location}
                    monthlyKwh={listing.monthlyKwh}
                    occupancyRate={listing.occupancyRate}
                    status={getStatus(listing.monthlyKwh, listing.occupancyRate)}
                    onCalculate={() => calculateSavingsForListing(listing.id)}
                    onEdit={() => {
                      setSelectedListing(listing)
                      setActiveTab('listings')
                    }}
                  />
                ))
              )}
            </div>
          </section>
        </div>
      )}

      {activeTab === 'listings' && (
        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">
          <section className=\"lg:col-span-2\">
            <div className=\"bg-slate-800 rounded-xl p-6\">
              <h2 className=\"text-xl font-semibold mb-4\">Propiedades</h2>
              <div className=\"overflow-x-auto\">
                <table className=\"w-full\">
                  <thead>
                    <tr className=\"text-left text-slate-400 border-b border-slate-700\">
                      <th className=\"py-3 px-4\">Nome</th>
                      <th className=\"py-3 px-4\">Localización</th>
                      <th className=\"py-3 px-4\">kWh/mes</th>
                      <th className=\"py-3 px-4\">Ocupación</th>
                      <th className=\"py-3 px-4\">Accións</th>
                    </tr>
                  </thead>
                  <tbody>
                    {listings.map(listing => (
                      <tr key={listing.id} className=\"border-b border-slate-700 hover:bg-slate-700/50\">
                        <td className=\"py-3 px-4 text-white font-medium\">{listing.name}</td>
                        <td className=\"py-3 px-4 text-slate-400 text-sm\">{listing.location}</td>
                        <td className=\"py-3 px-4 text-emerald-400 font-mono\">{listing.monthlyKwh}</td>
                        <td className=\"py-3 px-4 text-white\">{(listing.occupancyRate * 100).toFixed(0)}%</td>
                        <td className=\"py-3 px-4\">
                          <button onClick={() => calculateSavingsForListing(listing.id)} className=\"text-emerald-400 hover:text-emerald-300 text-sm mr-2\">Calcular</button>
                          <button onClick={() => { setSelectedListing(listing) }} className=\"text-slate-400 hover:text-slate-300 text-sm\">Editar</button>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <section>
            <div className=\"bg-slate-800 rounded-xl p-6\">
              <h2 className=\"text-xl font-semibold mb-4\">{selectedListing ? 'Editar Propiedade' : 'Nova Propiedade'}</h2>
              <form onSubmit={handleSubmitListing} className=\"space-y-4\">
                <div>
                  <label className=\"block text-slate-400 text-sm mb-1\">Nome</label>
                  <input
                    type=\"text\"
                    value={selectedListing ? selectedListing.name : form.name}
                    onChange={e => selectedListing ? setSelectedListing({ ...selectedListing, name: e.target.value }) : setForm({ ...form, name: e.target.value })}
                    className=\"w-full bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-white focus:border-emerald-500 focus:outline-none\"
                    placeholder=\"Apartamento Centro\"
                  />
                </div>
                <div>
                  <label className=\"block text-slate-400 text-sm mb-1\">Localización</label>
                  <input
                    type=\"text\"
                    value={selectedListing ? selectedListing.location : form.location}
                    onChange={e => selectedListing ? setSelectedListing({ ...selectedListing, location: e.target.value }) : setForm({ ...form, location: e.target.value })}
                    className=\"w-full bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-white focus:border-emerald-500 focus:outline-none\"
                    placeholder=\"Rúa Principal 42, Santiago\"
                  />
                </div>
                <div>
                  <label className=\"block text-slate-400 text-sm mb-1\">Consumo kWh/mes</label>
                  <input
                    type=\"number\"
                    value={selectedListing ? selectedListing.monthlyKwh : form.monthlyKwh}
                    onChange={e => selectedListing ? setSelectedListing({ ...selectedListing, monthlyKwh: parseInt(e.target.value) || 0 }) : setForm({ ...form, monthlyKwh: parseInt(e.target.value) || 0 })}
                    className=\"w-full bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-white focus:border-emerald-500 focus:outline-none\"
                  />
                </div>
                <div>
                  <label className=\"block text-slate-400 text-sm mb-1\">Taxa Ocupación (0-1)</label>
                  <input
                    type=\"number\"
                    step=\"0.1\"
                    min=\"0\"
                    max=\"1\"
                    value={selectedListing ? selectedListing.occupancyRate : form.occupancyRate}
                    onChange={e => selectedListing ? setSelectedListing({ ...selectedListing, occupancyRate: parseFloat(e.target.value) || 0 }) : setForm({ ...form, occupancyRate: parseFloat(e.target.value) || 0 })}
                    className=\"w-full bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-white focus:border-emerald-500 focus:outline-none\"
                  />
                </div>
                <div>
                  <label className=\"block text-slate-400 text-sm mb-1\">Contacto Propietario</label>
                  <input
                    type=\"email\"
                    value={selectedListing ? selectedListing.ownerContact : form.ownerContact}
                    onChange={e => selectedListing ? setSelectedListing({ ...selectedListing, ownerContact: e.target.value }) : setForm({ ...form, ownerContact: e.target.value })}
                    className=\"w-full bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-white focus:border-emerald-500 focus:outline-none\"
                    placeholder=\"email@exemplo.com\"
                  />
                </div>
                <button
                  type=\"submit\"
                  disabled={loading}
                  className=\"w-full bg-emerald-600 hover:bg-emerald-500 disabled:bg-slate-600 text-white font-medium py-2 rounded-lg transition\"
                >
                  {loading ? 'Gardando...' : selectedListing ? 'Actualizar' : 'Engadir Propiedade'}
                </button>
                {selectedListing && (
                  <button
                    type=\"button\"
                    onClick={() => setSelectedListing(null)}
                    className=\"w-full bg-slate-700 hover:bg-slate-600 text-white font-medium py-2 rounded-lg transition\"
                  >
                    Cancelar
                  </button>
                )}
              </form>
            </div>
          </section>
        </div>
      )}

      {activeTab === 'tariffs' && (
        <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-6\">
          <section className=\"lg:col-span-2\">
            <div className=\"bg-slate-800 rounded-xl p-6\">
              <h2 className=\"text-xl font-semibold mb-4\">Tarifas</h2>
              <div className=\"overflow-x-auto\">
                <table className=\"w-full\">
                  <thead>
                    <tr className=\"text-left text-slate-400 border-b border-slate-700\">
                      <th className=\"py-3 px-4\"> rexión</th>
                      <th className=\"py-3 px-4\">Proveedor</th>
                      <th className=\"py-3 px-4\">Base (€/kWh)</th>
                      <th className=\"py-3 px-4\">Pico (€/kWh)</th>
                      <th className=\"py-3 px-4\">Baixa Demanda (€/kWh)</th>
                    </tr>
                  </thead>
                  <tbody>
                    {tariffs.map(tariff => (
                      <tr key={tariff.id} className=\"border-b border-slate-700 hover:bg-slate-700/50\">
                        <td className=\"py-3 px-4 text-white font-medium\">{tariff.region}</td>
                        <td className=\"py-3 px-4 text-slate-400\">{tariff.provider}</td>
                        <td className=\"py-3 px-4 text-emerald-400 font-mono text-sm\">{tariff.baseRate.toFixed(4)}</td>
                        <td className=\"py-3 px-4 text-red-400 font-mono text-sm\">{tariff.peakRate.toFixed(4)}</td>
                        <td className=\"py-3 px-4 text-blue-400 font-mono text-sm\">{tariff.offPeakRate.toFixed(4)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </div>
          </section>

          <section>
            <div className=\"bg-slate-800 rounded-xl p-6\">
              <h2 className=\"text-xl font-semibold mb-4\">Nova Tarifa</h2>
              <form onSubmit={handleSubmitTariff} className=\"space-y-4\">
                <div>
                  <label className=\"block text-slate-400 text-sm mb-1\"> Rexión</label>
                  <input
                    type=\"text\"
                    value={tariffForm.region}
                    onChange={e => setTariffForm({ ...tariffForm, region: e.target.value })}
                    className=\"w-full bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-white focus:border-emerald-500 focus:outline-none\"
                    placeholder=\"Galicia\"
                  />
                </div>
                <div>
                  <label className=\"block text-slate-400 text-sm mb-1\">Proveedor</label>
                  <input
                    type=\"text\"
                    value={tariffForm.provider}
                    onChange={e => setTariffForm({ ...tariffForm, provider: e.target.value })}
                    className=\"w-full bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-white focus:border-emerald-500 focus:outline-none\"
                    placeholder=\"Endesa\"
                  />
                </div>
                <div>
                  <label className=\"block text-slate-400 text-sm mb-1\">Tarifa Base (€/kWh)</label>
                  <input
                    type=\"number\"
                    step=\"0.0001\"
