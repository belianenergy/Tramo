'use client'

import { useState, useEffect } from 'react'

interface Listing {
  id: number
  name: string
  location: string
  monthlyKwh: number
  occupancyRate: number
  ownerContact: string
  createdAt: string
}

interface Tariff {
  id: number
  region: string
  provider: string
  baseRate: number
  peakRate: number
  offPeakRate: number
}

interface DashboardData {
  totalListings: number
  totalKwh: number
  totalOccupancy: number
  totalSavingsMonthly: number
  totalSavingsYearly: number
  totalCostBefore: number
  totalCostAfter: number
  tariffsCount: number
  forecastsCount: number
}

interface SavingsResult {
  listingId: number
  listingName: string
  location: string
  monthlyKwh: number
  occupancyRate: number
  costBefore: number
  costAfter: number
  savingsMonthly: number
  savingsYearly: number
  tariffUsed: string
  breakdown: {
    peakHoursKwh: number
    offPeakHoursKwh: number
    baseCostPeak: number
    optimizedCostOffPeak: number
  }
}

export default function Home() {
  const [listings, setListings] = useState<Listing[]>([])
  const [tariffs, setTariffs] = useState<Tariff[]>([])
  const [dashboard, setDashboard] = useState<DashboardData | null>(null)
  const [form, setForm] = useState({ name: '', location: '', monthlyKwh: 0, occupancyRate: 0.7, ownerContact: '' })
  const [tariffForm, setTariffForm] = useState({ region: '', provider: '', baseRate: 0, peakRate: 0, offPeakRate: 0 })
  const [savings, setSavings] = useState<SavingsResult | null>(null)
  const [selectedListing, setSelectedListing] = useState<Listing | null>(null)
  const [loading, setLoading] = useState(false)
  const [activeTab, setActiveTab] = useState<'dashboard' | 'listings' | 'tariffs' | 'results'>('dashboard')

  useEffect(() => {
    fetchData()
  }, [])

  async function fetchData() {
    const [listingsRes, tariffsRes, dashRes] = await Promise.all([
      fetch('/api/listings'),
      fetch('/api/tariffs'),
      fetch('/api/dashboard'),
    ])
    if (listingsRes.ok) setListings(await listingsRes.json())
    if (tariffsRes.ok) setTariffs(await tariffsRes.json())
    if (dashRes.ok) setDashboard(await dashRes.json())
  }

  async function handleSubmitListing(e: React.FormEvent) {
    e.preventDefault()
    setLoading(true)
    const res = await fetch('/api/listings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(form),
    })
    if (res.ok) {
      setForm({ name: '', location: '', monthlyKwh: 0, occupancyRate: 0.7, ownerContact: '' })
      await fetchData()
    }
    setLoading(false)
  }

  async function handleSubmitTariff(e: React.FormEvent) {
    e.preventDefault()
    setLoading(true)
    const res = await fetch('/api/tariffs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(tariffForm),
    })
    if (res.ok) {
      setTariffForm({ region: '', provider: '', baseRate: 0, peakRate: 0, offPeakRate: 0 })
      await fetchData()
    }
    setLoading(false)
  }

  async function calculateSavingsForListing(listingId: number) {
    setLoading(true)
    const res = await fetch('/api/savings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ listingId }),
    })
    if (res.ok) {
      const data = await res.json()
      setSavings(data)
      setActiveTab('results')
    }
    setLoading(false)
  }

  async function exportCSV() {
    const res = await fetch('/api/export/csv', { method: 'POST' })
    if (res.ok) {
      const blob = await res.blob()
      const url = URL.createObjectURL(blob)
      const a = document.createElement('a')
      a.href = url
      a.download = 'energyos-report.csv'
      a.click()
    }
  }

  return (
    <main className="min-h-screen p-4 md:p-8 max-w-7xl mx-auto print:p-2 print:max-w-none">
      <header className="mb-8 print:mb-2">
        <h1 className="text-3xl md:text-4xl font-bold text-emerald-400">⚡ EnergyOS</h1>
        <p className="text-slate-400 mt-1">Xestión Enerxética Intelixente para Airbnb</p>
      </header>

      <nav className="flex gap-2 md:gap-4 mb-8 border-b border-slate-700 pb-4 print:hidden overflow-x-auto">
        {([
          ['dashboard', '📊 Dashboard'],
          ['listings', '🏠 Propiedades'],
          ['tariffs', '⚡ Tarifas'],
          ['results', '📈 Resultados'],
        ] as const).map(([key, label]) => (
          <button
            key={key}
            onClick={() => setActiveTab(key)}
            className={`px-3 md:px-4 py-2 rounded-lg font-medium transition whitespace-nowrap text-sm md:text-base ${
              activeTab === key
                ? 'bg-emerald-600 text-white'
                : 'bg-slate-800 text-slate-300 hover:bg-slate-700'
            }`}
          >
            {label}
          </button>
        ))}
      </nav>

      {activeTab === 'dashboard' && dashboard && (
        <div className="space-y-6">
          <section className="grid grid-cols-2 md:grid-cols-4 gap-4 print:grid-cols-4">
            <div className="bg-slate-800 rounded-xl p-4 md:p-6 text-center">
              <p className="text-slate-400 text-xs md:text-sm mb-1">Propiedades</p>
              <p className="text-2xl md:text-3xl font-bold text-white">{dashboard.totalListings}</p>
            </div>
            <div className="bg-slate-800 rounded-xl p-4 md:p-6 text-center">
              <p className="text-slate-400 text-xs md:text-sm mb-1">Consumo total</p>
              <p className="text-2xl md:text-3xl font-bold text-yellow-400">{dashboard.totalKwh}<span className="text-sm"> kWh/mes</span></p>
            </div>
            <div className="bg-slate-800 rounded-xl p-4 md:p-6 text-center">
              <p className="text-slate-400 text-xs md:text-sm mb-1">Aforro mensual</p>
              <p className="text-2xl md:text-3xl font-bold text-emerald-400">{dashboard.totalSavingsMonthly}€</p>
            </div>
            <div className="bg-emerald-900/50 border border-emerald-700 rounded-xl p-4 md:p-6 text-center">
              <p className="text-emerald-400 text-xs md:text-sm mb-1">Aforro anual</p>
              <p className="text-2xl md:text-3xl font-bold text-emerald-300">{dashboard.totalSavingsYearly}€</p>
            </div>
          </section>

          <section className="grid grid-cols-1 md:grid-cols-2 gap-4 print:grid-cols-2">
            <div className="bg-slate-800 rounded-xl p-6">
              <h3 className="font-semibold mb-3 text-slate-300">💰 Custo sen optimizar</h3>
              <p className="text-3xl font-bold text-red-400">{dashboard.totalCostBefore}€<span className="text-sm text-slate-400">/mes</span></p>
            </div>
            <div className="bg-slate-800 rounded-xl p-6">
              <h3 className="font-semibold mb-3 text-slate-300">✅ Custo optimizado</h3>
              <p className="text-3xl font-bold text-emerald-400">{dashboard.totalCostAfter}€<span className="text-sm text-slate-400">/mes</span></p>
            </div>
          </section>

          <section className="bg-slate-800 rounded-xl p-6">
            <div className="flex justify-between items-center mb-4 print:hidden">
              <h3 className="font-semibold">Propiedades rexistradas</h3>
              <button onClick={() => setActiveTab('listings')} className="text-emerald-400 hover:text-emerald-300 text-sm">+ Engadir</button>
            </div>
            {listings.length === 0 ? (
              <p className="text-slate-500 text-center py-8">Aínda non hai propiedades. Engade a primeira!</p>
            ) : (
              <div className="space-y-3 print:space-y-1">
                {listings.map((listing) => (
                  <div key={listing.id} className="bg-slate-700 rounded-lg p-4 flex justify-between items-center print:p-2">
                    <div>
                      <h4 className="font-bold text-white print:text-sm">{listing.name}</h4>
                      <p className="text-sm text-slate-400">{listing.location} · {listing.monthlyKwh} kWh · {(listing.occupancyRate * 100).toFixed(0)}% ocupación</p>
                    </div>
                    <div className="flex gap-2 print:hidden">
                      <button onClick={() => { setSelectedListing(listing); setActiveTab('results') }} className="bg-slate-600 hover:bg-slate-500 text-white px-3 py-1 rounded text-sm">Detalle</button>
                      <button onClick={() => calculateSavingsForListing(listing.id)} className="bg-emerald-600 hover:bg-emerald-500 text-white px-3 py-1 rounded text-sm">Aforro</button>
                    </div>
                  </div>
                ))}
              </div>
            )}
          </section>

          <div className="print:hidden">
            <button onClick={exportCSV} className="bg-slate-700 hover:bg-slate-600 text-white px-4 py-2 rounded-lg font-medium transition w-full">
              📥 Exportar todo a CSV
            </button>
          </div>
        </div>
      )}

      {activeTab === 'listings' && (
        <div className="grid grid-cols-1 lg:grid-cols-2 gap-8">
