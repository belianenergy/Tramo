'use client'

import { useState, useEffect } from 'react'

interface Listing {
  id: number
  name: string
  location: string
  monthlyKwh: number
  occupancyRate: number
  ownerContact: string
  createdAt: string
}

interface Tariff {
  id: number
  region: string
  provider: string
  baseRate: number
  peakRate: number
  offPeakRate: number
}

interface DashboardData {
  totalListings: number
  totalKwh: number
  totalOccupancy: number
  totalSavingsMonthly: number
  totalSavingsYearly: number
  totalCostBefore: number
  totalCostAfter: number
  tariffsCount: number
  forecastsCount: number
}

interface SavingsResult {
  listingId: number
  listingName: string
  location: string
  monthlyKwh: number
  occupancyRate: number
  costBefore: number
  costAfter: number
  savingsMonthly: number
  savingsYearly: number
  tariffUsed: string
  breakdown: {
    peakHoursKwh: number
    offPeakHoursKwh: number
    baseCostPeak: number
    optimizedCostOffPeak: number
  }
}

type Period = 'month' | 'quarter' | 'year'

// Componente do gráfico SVG
function ConsumptionChart({ 
  listings, 
  period 
}: { 
  listings: Listing[]
  period: Period 
}) {
  const multiplier = period === 'month' ? 1 : period === 'quarter' ? 3 : 12
  const maxKwh = Math.max(...listings.map(l => l.monthlyKwh * multiplier))
  const width = 600
  const height = 200
  const padding = 40
  const barWidth = 40
  const gap = (width - 2 * padding - listings.length * barWidth) / (listings.length + 1)

  const chartData = listings.map(l => ({
    name: l.name.length > 15 ? l.name.substring(0, 12) + '...' : l.name,
    kwh: l.monthlyKwh * multiplier,
    highConsumption: l.monthlyKwh > 1000
  }))

  return (
    <svg viewBox={"'`0 0 ${width} ${height}`} className="w-full h-auto max-h-64">
      {/* Grade lines */}
      {[0.25, 0.5, 0.75, 1].map((ratio, i) => (
        <g key={i}>
          <line
            x1={padding}
            y1={padding + (height - 2 * padding) * ratio}
            x2={width - padding}
            y2={padding + (height - 2 * padding) * ratio}
            stroke="#334155"
            strokeWidth="1"
            strokeDasharray="4"
          />
          <text
            x={padding - 8}
            y={padding + (height - 2 * padding) * ratio + 4}
            fill="#94a3b8"
            fontSize="10"
            textAnchor="end"
          >
            {Math.round(maxKwh * ratio)}
          </text>
        </g>
      ))}

      {/* Barras */}
      {chartData.map((item, i) => {
        const barHeight = (item.kwh / maxKwh) * (height - 2 * padding)
        const x = padding + gap + i * (barWidth + gap)
        const y = height - padding - barHeight
        const fill = item.highConsumption ? '"'#f59e0b' : '#10b981'

        return (
          <g key={i}>
            <rect
              x={x}
              y={y}
              width={barWidth}
              height={barHeight}
              fill={fill}
              rx=\"4\"
              className=\"transition-all duration-300 hover:opacity-80\"
            />
            {/* Raio para alto consumo */}
            {item.highConsumption && (
              <text
                x={x + barWidth / 2}
                y={y - 8}
                fill=\"#fbbf24\"
                fontSize=\"14\"
                textAnchor=\"middle\"
              >
                ⚡
              </text>
            )}
            {/* Etiqueta inferior */}
            <text
              x={x + barWidth / 2}
              y={height - padding + 20}
              fill=\"#94a3b8\"
              fontSize=\"9\"
              textAnchor=\"middle\"
            >
              {item.name}
            </text>
            {/* Valor enriba */}
            <text
              x={x + barWidth / 2}
              y={y - 4}
              fill=\"#fff\"
              fontSize=\"10\"
              textAnchor=\"middle\"
              fontWeight=\"bold\"
            >
              {item.kwh.toLocaleString()}
            </text>
          </g>
        )
      })}

      {/* Eixe Y label */}
      <text
        x={15}
        y={height / 2}
        fill=\"#64748b\"
        fontSize=\"10\"
        textAnchor=\"middle\"
        transform={"'`rotate(-90, 15, ${height / 2})`}
      >
        kWh
      </text>
    </svg>
  )
}

// Selector de período
function PeriodSelector({ 
  period, 
  onChange 
}: { 
  period: Period
  onChange: (p: Period) => void 
}) {
  const options: { value: Period; label: string }[] = [
    { value: '"'month', label: 'Último Mes' },
    { value: 'quarter', label: 'Último Trimestre' },
    { value: 'year', label: 'Último Ano' }
  ]

  return (
    <div className=\"flex gap-2 bg-slate-800 p-1 rounded-lg\">
      {options.map(opt => (
        <button
          key={opt.value}
          onClick={() => onChange(opt.value)}
          className={"'`px-4 py-2 rounded-md text-sm font-medium transition ${
            period === opt.value
              ? '"'bg-emerald-600 text-white'
              : 'text-slate-400 hover:text-white hover:bg-slate-700'
          }"'`}
        >
          {opt.label}
        </button>
      ))}
    </div>
  )
}

// Tarxeta de propiedade mellorada
function PropertyCard({ 
  listing, 
  onCalculate 
}: { 
  listing: Listing
  onCalculate: (id: number) => void 
}) {
  const isHighConsumption = listing.monthlyKwh > 1000
  const savingsPercent = 25 // Simulado para demo

  return (
    <div className={`relative bg-slate-800 rounded-xl p-5 border transition ${
      isHighConsumption ? '"'border-amber-600/50 hover:border-amber-500' : 'border-slate-700 hover:border-slate-600'
    }"'`}>
      {/* Badge aforro */}
      {savingsPercent > 20 && (
        <div className="absolute -top-2 -right-2 bg-green-500 text-white text-xs font-bold px-2 py-1 rounded-full shadow-lg">
          🟢 -{savingsPercent}% aforro
        </div>
      )}

      {/* Header */}
      <div className="flex justify-between items-start mb-3">
        <div>
          <h3 className="font-semibold text-white flex items-center gap-2">
            {listing.name}
            {isHighConsumption && (
              <span className="text-amber-400" title="Alto consumo">⚡</span>
            )}
          </h3>
          <p className="text-slate-400 text-sm">{listing.location}</p>
        </div>
        {isHighConsumption && (
          <span className="bg-amber-900/50 text-amber-300 text-xs px-2 py-1 rounded-full">
            Alto consumo
          </span>
        )}
      </div>

      {/* Metrics */}
      <div className="grid grid-cols-2 gap-3 mb-4">
        <div className="bg-slate-700/50 rounded-lg p-3">
          <p className="text-slate-400 text-xs mb-1">Consumo Mensual</p>
          <p className={`text-lg font-bold ${isHighConsumption ? '"'text-amber-400' : 'text-emerald-400'}"'`}>
            {listing.monthlyKwh.toLocaleString()} <span className="text-xs text-slate-400">kWh</span>
          </p>
        </div>
        <div className="bg-slate-700/50 rounded-lg p-3">
          <p className="text-slate-400 text-xs mb-1">Ocupación</p>
          <p className="text-lg font-bold text-blue-400">
            {(listing.occupancyRate * 100).toFixed(0)}<span className="text-xs text-slate-400">%</span>
          </p>
        </div>
      </div>

      {/* Barra de progreso do consumo */}
      <div className="mb-4">
        <div className="flex justify-between text-xs text-slate-400 mb-1">
          <span>Nivel consumo</span>
          <span>{Math.round((listing.monthlyKwh / 1500) * 100)}%</span>
        </div>
        <div className="h-2 bg-slate-700 rounded-full overflow-hidden">
          <div 
            className={`h-full rounded-full transition-all ${
              isHighConsumption ? '"'bg-gradient-to-r from-amber-500 to-amber-400' : 'bg-gradient-to-r from-emerald-500 to-emerald-400'
            }"'`}
            style={{ width: `${Math.min((listing.monthlyKwh / 1500) * 100, 100)}%` }}
          />
        </div>
      </div>

      <button
        onClick={() => onCalculate(listing.id)}
        className="w-full bg-emerald-600 hover:bg-emerald-500 text-white py-2 rounded-lg font-medium transition text-sm"
      >
        Calcular Aforro
      </button>
    </div>
  )
}

export default function Home() {
  const [listings, setListings] = useState<Listing[]>([])
  const [tariffs, setTariffs] = useState<Tariff[]>([])
  const [dashboard, setDashboard] = useState<DashboardData | null>(null)
  const [form, setForm] = useState({ name: '"'', location: '', monthlyKwh: 0, occupancyRate: 0.7, ownerContact: '' })
  const [tariffForm, setTariffForm] = useState({ region: '', provider: '', baseRate: 0, peakRate: 0, offPeakRate: 0 })
  const [savings, setSavings] = useState<SavingsResult | null>(null)
  const [selectedListing, setSelectedListing] = useState<Listing | null>(null)
  const [loading, setLoading] = useState(false)
  const [activeTab, setActiveTab] = useState<'dashboard' | 'listings' | 'tariffs' | 'results'>('dashboard')
  const [period, setPeriod] = useState<Period>('month')

  useEffect(() => {
    fetchData()
  }, [])

  async function fetchData() {
    const [listingsRes, tariffsRes, dashRes] = await Promise.all([
      fetch('/api/listings'),
      fetch('/api/tariffs'),
      fetch('/api/dashboard'),
    ])
    if (listingsRes.ok) setListings(await listingsRes.json())
    if (tariffsRes.ok) setTariffs(await tariffsRes.json())
    if (dashRes.ok) setDashboard(await dashRes.json())
  }

  async function handleSubmitListing(e: React.FormEvent) {
    e.preventDefault()
    setLoading(true)
    const res = await fetch('/api/listings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(form),
    })
    if (res.ok) {
      setForm({ name: '', location: '', monthlyKwh: 0, occupancyRate: 0.7, ownerContact: '' })
      await fetchData()
    }
    setLoading(false)
  }

  async function handleSubmitTariff(e: React.FormEvent) {
    e.preventDefault()
    setLoading(true)
    const res = await fetch('/api/tariffs', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(tariffForm),
    })
    if (res.ok) {
      setTariffForm({ region: '', provider: '', baseRate: 0, peakRate: 0, offPeakRate: 0 })
      await fetchData()
    }
    setLoading(false)
  }

  async function calculateSavingsForListing(listingId: number) {
    setLoading(true)
    const res = await fetch('/api/savings', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ listingId }),
    })
    if (res.ok) {
      const data = await res.json()
      setSavings(data)
      setActiveTab('results')
    }
    setLoading(false)
  }

  async function exportCSV() {
    const res = await fetch('/api/export/csv', { method: 'POST' })
    if (res.ok) {
      const blob = await res.blob()
      const url = URL.createObjectURL(blob)
      const a = document.createElement('a')
      a.href = url
      a.download = 'energyos-report.csv'
      a.click()
    }
  }

  return (
    <main className=\"min-h-screen p-4 md:p-8 max-w-7xl mx-auto print:p-2 print:max-w-none\">
      <header className=\"mb-8 print:mb-2\">
        <h1 className=\"text-3xl md:text-4xl font-bold text-emerald-400\">⚡ EnergyOS</h1>
        <p className=\"text-slate-400 mt-1\">Xestión Enerxética Intelixente para Airbnb</p>
      </header>

      <nav className=\"flex gap-2 md:gap-4 mb-8 border-b border-slate-700 pb-4 print:hidden overflow-x-auto\">
        {([
          ['dashboard', '📊 Dashboard'],
          ['listings', '🏠 Propiedades'],
          ['tariffs', '⚡ Tarifas'],
          ['results', '📈 Resultados'],
        ] as const).map(([key, label]) => (
          <button
            key={key}
            onClick={() => setActiveTab(key)}
            className={"'`px-3 md:px-4 py-2 rounded-lg font-medium transition whitespace-nowrap text-sm md:text-base ${
              activeTab === key
                ? '"'bg-emerald-600 text-white'
                : 'bg-slate-800 text-slate-300 hover:bg-slate-700'
            }"'`}
          >
            {label}
          </button>
        ))}
      </nav>

      {activeTab === '"'dashboard' && dashboard && (
        <div className=\"space-y-6\">
          {/* Stats grid */}
          <section className=\"grid grid-cols-2 md:grid-cols-4 gap-4 print:grid-cols-4\">
            <div className=\"bg-slate-800 rounded-xl p-4 text-center print:break-inside-avoid\">
              <p className=\"text-slate-400 text-xs mb-1\">Propiedades</p>
              <p className=\"text-2xl font-bold text-white\">{dashboard.totalListings}</p>
            </div>
            <div className=\"bg-slate-800 rounded-xl p-4 text-center print:break-inside-avoid\">
              <p className=\"text-slate-400 text-xs mb-1\">Consumo Total</p>
              <p className=\"text-2xl font-bold text-blue-400\">{dashboard.totalKwh.toLocaleString()} <span className=\"text-xs text-slate-400\">kWh</span></p>
            </div>
            <div className=\"bg-slate-800 rounded-xl p-4 text-center print:break-inside-avoid\">
              <p className=\"text-slate-400 text-xs mb-1\">Aforro Mensual</p>
              <p className=\"text-2xl font-bold text-emerald-400\">{dashboard.totalSavingsMonthly.toFixed(2)}€</p>
            </div>
            <div className=\"bg-slate-800 rounded-xl p-4 text-center print:break-inside-avoid\">
              <p className=\"text-slate-400 text-xs mb-1\">Aforro Anual</p>
              <p className=\"text-2xl font-bold text-emerald-400\">{dashboard.totalSavingsYearly.toFixed(2)}€</p>
            </div>
          </section>

          {/* Gráfico de consumo */}
          <section className=\"bg-slate-800 rounded-xl p-6 print:break-inside-avoid\">
            <div className=\"flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-4\">
              <h2 className=\"text-xl font-semibold\">📊 Consumo por Propiedade</h2>
              <PeriodSelector period={period} onChange={setPeriod} />
            </div>
            
            <div className=\"bg-slate-900/50 rounded-lg p-4\">
              <ConsumptionChart listings={listings} period={period} />
            </div>

            <div className=\"flex gap-6 mt-4 text-sm\">
              <div className=\"flex items-center gap-2\">
                <span className=\"w-3 h-3 rounded bg-emerald-500\"></span>
                <span className=\"text-slate-400\">Consumo normal (&lt;1000 kWh)</span>
              </div>
              <div className=\"flex items-center gap-2\">
                <span className=\"w-3 h-3 rounded bg-amber-500\"></span>
                <span className=\"text-slate-400\">Alto consumo (&gt;1000 kWh) ⚡</span>
              </div>
            </div>
          </section>

          {/* Listado rápido de propiedades */}
          <section className=\"bg-slate-800 rounded-xl p-6\">
            <div className=\"flex justify-between items-center mb-4\">
              <h2 className=\"text-xl font-semibold\">🏠 Propiedades</h2>
              <button onClick={() => setActiveTab('listings')} className=\"text-emerald-400 hover:text-emerald-300 text-sm\">
                Ver todas →
              </button>
            </div>
            <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4\">
              {listings.map(listing => (
                <PropertyCard 
                  key={listing.id} 
                  listing={listing} 
                  onCalculate={calculateSavingsForListing}
                />
              ))}
            </div>
          </section>
        </div>
      )}

      {activeTab === 'listings' && (
        <div className=\"space-y-6\">
          <section className=\"bg-slate-800 rounded-xl p-6\">
            <h2 className=\"text-xl font-semibold mb-4\">Engadir Propiedade</h2>
            <form onSubmit={handleSubmitListing} className=\"grid grid-cols-1 md:grid-cols-2 gap-4\">
              <input type=\"text\" placeholder=\"Nome da propiedade\" required
                value={form.name}
