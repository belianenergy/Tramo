'use client'

import { useState } from 'react'

type Period = 'month' | 'quarter' | 'year'

// ─── Design Tokens (from DESIGN.md) ─────────────────────────────────────────
const TOKENS = {
  colors: {
    primary: '#059669',
    primaryLight: '#10b981',
    primaryDark: '#047857',
    secondary: '#1e293b',
    secondaryLight: '#334155',
    neutral: '#f8fafc',
    neutralMuted: '#94a3b8',
    danger: '#ef4444',
    dangerLight: '#fca5a5',
    warning: '#f59e0b',
    background: '#0f172a',
    surface: '#1e293b',
  },
  spacing: { xs: '0.25rem', sm: '0.5rem', md: '1rem', lg: '1.5rem', xl: '2rem', '2xl': '3rem' },
  rounded: { sm: '0.25rem', md: '0.5rem', lg: '0.75rem', xl: '1rem', full: '9999px' },
}

// ─── Trend Arrow ─────────────────────────────────────────────────────────────
function TrendArrow({ value }: { value: number }) {
  if (value === 0) return <span className="text-slate-500 text-sm">—</span>
  const up = value > 0
  return (
    <span className={`flex items-center gap-0.5 text-xs font-medium ${up ? 'text-red-400' : 'text-emerald-400'}`}>
      {up ? '↑' : '↓'} {Math.abs(value).toFixed(1)}%
    </span>
  )
}

// ─── Status Badge ─────────────────────────────────────────────────────────────
function StatusBadge({ status }: { status: 'success' | 'warning' | 'danger' | 'muted' }) {
  const map = {
    success: { bg: '#059669', color: '#fff', label: 'Normal' },
    warning: { bg: '#f59e0b', color: '#000', label: 'Atención' },
    danger: { bg: '#ef4444', color: '#fff', label: 'Alerta' },
    muted: { bg: '#334155', color: '#94a3b8', label: 'Inactivo' },
  }
  const s = map[status]
  return (
    <span
      className="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium uppercase tracking-wide"
      style={{ backgroundColor: s.bg, color: s.color }}
    >
      {s.label}
    </span>
  )
}

// ─── MetricCard ───────────────────────────────────────────────────────────────
function MetricCard({
  label,
  value,
  unit,
  icon,
  trend,
  color = '#10b981',
}: {
  label: string
  value: string | number
  unit?: string
  icon: string
  trend?: number
  color?: string
}) {
  return (
    <div
      className="relative overflow-hidden rounded-xl p-5 border transition-all duration-200 hover:border-emerald-600/50"
      style={{ backgroundColor: TOKENS.colors.surface, borderColor: TOKENS.colors.secondaryLight }}
    >
      {/* Glow accent */}
      <div
        className="absolute top-0 right-0 w-20 h-20 rounded-full opacity-10 blur-xl"
        style={{ backgroundColor: color, transform: 'translate(30%, -30%)' }}
      />

      <div className="flex items-start justify-between mb-3">
        <span className="text-2xl">{icon}</span>
        {trend !== undefined && <TrendArrow value={trend} />}
      </div>

      <p className="text-xs font-medium uppercase tracking-widest mb-1" style={{ color: TOKENS.colors.neutralMuted }}>
        {label}
      </p>
      <p className="text-3xl font-bold" style={{ color: TOKENS.colors.neutral, lineHeight: 1.1 }}>
        {value}
        {unit && <span className="text-base font-normal ml-1" style={{ color: TOKENS.colors.neutralMuted }}>{unit}</span>}
      </p>
    </div>
  )
}

// ─── ConsumptionAreaChart ──────────────────────────────────────────────────────
function ConsumptionAreaChart({
  data,
  period,
}: {
  data: { name: string; kwh: number }[]
  period: Period
}) {
  const multiplier = period === 'month' ? 1 : period === 'quarter' ? 3 : 12
  const values = data.map((d) => d.kwh * multiplier)
  const max = Math.max(...values, 1)
  const width = 640
  const height = 220
  const padX = 48
  const padY = 24
  const chartW = width - padX * 2
  const chartH = height - padY * 2

  // Build SVG path for area + line
  const points = values.map((v, i) => ({
    x: padX + (i / Math.max(values.length - 1, 1)) * chartW,
    y: padY + chartH - (v / max) * chartH,
  }))

  const linePath =
    points.length < 2
      ? `M ${points[0]?.x ?? padX} ${points[0]?.y ?? padY + chartH}`
      : points
          .map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`)
          .join(' ')

  const areaPath =
    points.length < 2
      ? `${linePath} L ${padX} ${padY + chartH} Z`
      : `${linePath} L ${points[points.length - 1].x} ${padY + chartH} L ${points[0].x} ${padY + chartH} Z`

  // Y-axis ticks
  const ticks = [0, 0.25, 0.5, 0.75, 1].map((t) => ({
    y: padY + chartH * (1 - t),
    label: Math.round(max * t).toLocaleString(),
  }))

  // X-axis labels (abbreviated property names)
  const xLabels = data.map((d, i) => ({
    x: padX + (i / Math.max(data.length - 1, 1)) * chartW,
    label: d.name.length > 10 ? d.name.substring(0, 8) + '…' : d.name,
  }))

  return (
    <svg viewBox={`0 0 ${width} ${height}`} className="w-full h-auto" style={{ maxHeight: '240px' }}>
      {/* Grid lines */}
      {ticks.map((t, i) => (
        <g key={i}>
          <line x1={padX} y1={t.y} x2={width - padX} y2={t.y} stroke="#334155" strokeWidth="1" strokeDasharray="4" />
          <text x={padX - 8} y={t.y + 4} fill="#94a3b8" fontSize="10" textAnchor="end">
            {t.label}
          </text>
        </g>
      ))}

      {/* Area fill */}
      <path d={areaPath} fill="#059669" fillOpacity="0.15" />

      {/* Line */}
      <path d={linePath} fill="none" stroke="#10b981" strokeWidth="2.5" strokeLinejoin="round" strokeLinecap="round" />

      {/* Data points */}
      {points.map((p, i) => (
        <circle key={i} cx={p.x} cy={p.y} r="4" fill="#10b981" stroke="#0f172a" strokeWidth="2" />
      ))}

      {/* X labels */}
      {xLabels.map((l, i) => (
        <text key={i} x={l.x} y={height - 6} fill="#94a3b8" fontSize="9" textAnchor="middle">
          {l.label}
        </text>
      ))}

      {/* Y label */}
      <text
        x={14}
        y={height / 2}
        fill="#64748b"
        fontSize="10"
        textAnchor="middle"
        transform={`rotate(-90, 14, ${height / 2})`}
      >
        kWh
      </text>

      {/* Tooltip hint */}
      <text x={width / 2} y={padY - 6} fill="#475569" fontSize="9" textAnchor="middle">
        Consumo {period === 'month' ? 'mensual' : period === 'quarter' ? 'trimestral' : 'anual'} por propiedade
      </text>
    </svg>
  )
}

// ─── PropertyCard ─────────────────────────────────────────────────────────────
interface Listing {
  id: number
  name: string
  location: string
  monthlyKwh: number
  occupancyRate: number
}

function PropertyCardV2({
  listing,
  onCalculate,
  savings,
}: {
  listing: Listing
  onCalculate: (id: number) => void
  savings?: number
}) {
  const consumptionLevel = listing.monthlyKwh > 1000 ? 'danger' : listing.monthlyKwh > 700 ? 'warning' : 'success'
  const consumptionColor = {
    success: '#10b981',
    warning: '#f59e0b',
    danger: '#ef4444',
  }[consumptionLevel]

  const statusMap = {
    success: 'success' as const,
    warning: 'warning' as const,
    danger: 'danger' as const,
  }
  const status = statusMap[consumptionLevel]

  const barWidth = Math.min((listing.monthlyKwh / 1500) * 100, 100)

  return (
    <div
      className="rounded-xl p-5 border transition-all duration-200 hover:border-emerald-600/40 flex flex-col gap-4"
      style={{ backgroundColor: TOKENS.colors.surface, borderColor: TOKENS.colors.secondaryLight }}
    >
      {/* Header */}
      <div className="flex justify-between items-start">
        <div className="flex-1 min-w-0">
          <h3 className="font-semibold text-white text-base truncate" title={listing.name}>
            {listing.name}
          </h3>
          <p className="text-slate-400 text-xs mt-0.5 truncate">{listing.location}</p>
        </div>
        <StatusBadge status={status} />
      </div>

      {/* Key metrics row */}
      <div className="grid grid-cols-2 gap-3">
        <div className="rounded-lg p-3" style={{ backgroundColor: '#0f172a' }}>
          <p className="text-slate-500 text-xs mb-1 uppercase tracking-wide font-medium">Consumo</p>
          <p className="text-xl font-bold" style={{ color: consumptionColor }}>
            {listing.monthlyKwh.toLocaleString()}
            <span className="text-xs font-normal text-slate-500 ml-1">kWh</span>
          </p>
        </div>
        <div className="rounded-lg p-3" style={{ backgroundColor: '#0f172a' }}>
          <p className="text-slate-500 text-xs mb-1 uppercase tracking-wide font-medium">Ocupación</p>
          <p className="text-xl font-bold text-blue-400">
            {(listing.occupancyRate * 100).toFixed(0)}
            <span className="text-xs font-normal text-slate-500 ml-1">%</span>
          </p>
        </div>
      </div>

      {/* Consumption bar */}
      <div>
        <div className="flex justify-between text-xs text-slate-400 mb-1.5">
          <span>Nivel consumo</span>
          <span>{barWidth.toFixed(0)}%</span>
        </div>
        <div className="h-2 rounded-full overflow-hidden" style={{ backgroundColor: '#0f172a' }}>
          <div
            className="h-full rounded-full transition-all duration-500"
            style={{
              width: `${barWidth}%`,
              background: `linear-gradient(90deg, ${consumptionColor}cc, ${consumptionColor})`,
            }}
          />
        </div>
      </div>

      {/* Savings highlight */}
      {savings !== undefined && savings > 0 && (
        <div
          className="rounded-lg p-3 flex items-center justify-between"
          style={{ backgroundColor: '#04785730', border: '1px solid #05966950' }}
        >
          <div>
            <p className="text-emerald-400 text-xs font-medium">Aforro potencial</p>
            <p className="text-lg font-bold text-emerald-300">{savings.toFixed(2)}€<span className="text-xs font-normal text-emerald-500">/mes</span></p>
          </div>
          <span className="text-2xl">💡</span>
        </div>
      )}

      {/* CTA */}
      <button
        onClick={() => onCalculate(listing.id)}
        className="w-full py-2 rounded-lg text-sm font-medium text-white transition-all duration-200 hover:opacity-90 active:scale-98"
        style={{ backgroundColor: TOKENS.colors.primary }}
      >
        Calcular Aforro
      </button>
    </div>
  )
}

// ─── Period Selector ───────────────────────────────────────────────────────────
function PeriodSelectorV2({ period, onChange }: { period: Period; onChange: (p: Period) => void }) {
  const options: { value: Period; label: string }[] = [
    { value: 'month', label: 'Mes' },
    { value: 'quarter', label: 'Trimestre' },
    { value: 'year', label: 'Ano' },
  ]
  return (
    <div
      className="flex gap-1 p-1 rounded-lg"
      style={{ backgroundColor: TOKENS.colors.secondary }}
    >
      {options.map((opt) => (
        <button
          key={opt.value}
          onClick={() => onChange(opt.value)}
          className="px-4 py-1.5 rounded-md text-sm font-medium transition-all duration-150"
          style={
            period === opt.value
              ? { backgroundColor: TOKENS.colors.primary, color: '#fff' }
              : { color: TOKENS.colors.neutralMuted }
          }
        >
          {opt.label}
        </button>
      ))}
    </div>
  )
}

