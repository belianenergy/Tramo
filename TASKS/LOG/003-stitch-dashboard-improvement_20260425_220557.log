              <input type="number" step="0.0001" placeholder="Tarifa hora baixa (€/kWh)" required
                value={tariffForm.offPeakRate || ''}
                onChange={e => setTariffForm({ ...tariffForm, offPeakRate: Number(e.target.value) })}
                className="bg-slate-700 border border-slate-600 rounded-lg px-4 py-2 text-white placeholder-slate-400 focus:border-emerald-500 focus:outline-none"
              />
              <button type="submit" disabled={loading}
                className="bg-emerald-600 hover:bg-emerald-500 disabled:bg-slate-600 text-white py-2 rounded-lg font-medium transition">
                {loading ? 'Engadindo...' : 'Engadir Tarifa'}
              </button>
            </form>
          </section>

          <section className="bg-slate-800 rounded-xl overflow-hidden">
            <div className="overflow-x-auto">
              <table className="w-full">
                <thead className="bg-slate-700 text-slate-300 text-sm">
                  <tr>
                    <th className="py-3 px-4 text-left font-medium">Rexión</th>
                    <th className="py-3 px-4 text-left font-medium">Proveedor</th>
                    <th className="py-3 px-4 text-left font-medium">Base</th>
                    <th className="py-3 px-4 text-left font-medium">Punta</th>
                    <th className="py-3 px-4 text-left font-medium">Baixa Demanda</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-slate-700">
                  {tariffs.map(tariff => (
                    <tr key={tariff.id} className="hover:bg-slate-700/50 transition">
                      <td className="py-3 px-4 text-white">{tariff.region}</td>
                      <td className="py-3 px-4 text-slate-400 text-sm">{tariff.provider}</td>
                      <td className="py-3 px-4 text-white font-mono text-sm">{tariff.baseRate.toFixed(4)}</td>
                      <td className="py-3 px-4 text-red-400 font-mono text-sm">{tariff.peakRate.toFixed(4)}</td>
                      <td className="py-3 px-4 text-blue-400 font-mono text-sm">{tariff.offPeakRate.toFixed(4)}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        </div>
      )}

      {activeTab === 'results' && (
        <div className="space-y-6">
          <section className="bg-slate-800 rounded-xl p-6 print:hidden">
            <div className="flex justify-between items-center mb-4">
              <h2 className="text-xl font-semibold">Resultados</h2>
              <button onClick={exportCSV} className="bg-slate-700 hover:bg-slate-600 text-white px-4 py-2 rounded-lg font-medium transition">📥 CSV</button>
            </div>

            {!savings ? (
              <div className="text-center py-12">
                <p className="text-slate-400 mb-4">Selecciona unha propiedade para calcular o aforro.</p>
                <button onClick={() => setActiveTab('listings')} className="bg-emerald-600 hover:bg-emerald-500 text-white px-6 py-2 rounded-lg">
                  Ir a Propiedades
                </button>
              </div>
            ) : (
              <div className="space-y-6">
                <div className="grid grid-cols-1 md:grid-cols-3 gap-6 print:grid-cols-3">
                  <div className="bg-slate-700 rounded-xl p-6 text-center">
                    <p className="text-slate-400 text-sm mb-2">Custo Actual</p>
                    <p className="text-3xl font-bold text-red-400">{savings.costBefore.toFixed(2)}€<span className="text-sm text-slate-400">/mes</span></p>
                    <p className="text-xs text-slate-500 mt-1">Sen optimización</p>
                  </div>
                  <div className="bg-slate-700 rounded-xl p-6 text-center">
                    <p className="text-slate-400 text-sm mb-2">Custo Optimizado</p>
                    <p className="text-3xl font-bold text-emerald-400">{savings.costAfter.toFixed(2)}€<span className="text-sm text-slate-400">/mes</span></p>
                    <p className="text-xs text-slate-500 mt-1">Con horarios baixa demanda</p>
                  </div>
                  <div className="bg-emerald-900/50 border border-emerald-700 rounded-xl p-6 text-center">
                    <p className="text-emerald-400 text-sm mb-2">Aforro Mensual</p>
                    <p className="text-3xl font-bold text-emerald-300">{savings.savingsMonthly.toFixed(2)}€<span className="text-sm text-emerald-500">/mes</span></p>
                    <p className="text-xs text-emerald-600 mt-1">~{savings.savingsYearly.toFixed(2)}€/ano</p>
                  </div>
                </div>

                <div className="bg-slate-700 rounded-xl p-6 print:break-inside-avoid">
                  <h3 className="font-semibold mb-3">📋 Detalle</h3>
                  <div className="grid grid-cols-2 gap-3 text-sm">
                    <div><span className="text-slate-400">Propiedade:</span> <span className="text-white">{savings.listingName}</span></div>
                    <div><span className="text-slate-400">Localización:</span> <span className="text-white">{savings.location}</span></div>
                    <div><span className="text-slate-400">Consumo:</span> <span className="text-white">{savings.monthlyKwh} kWh/mes</span></div>
                    <div><span className="text-slate-400">Ocupación:</span> <span className="text-white">{(savings.occupancyRate * 100).toFixed(0)}%</span></div>
                    <div><span className="text-slate-400">Tarifa:</span> <span className="text-white">{savings.tariffUsed}</span></div>
                    <div><span className="text-slate-400">Factor ocupación:</span> <span className="text-white">{savings.occupancyRate > 0.8 ? 'Alta (30%)' : savings.occupancyRate > 0.5 ? 'Media (65%)' : 'Baixa (90%)'}</span></div>
                  </div>
                </div>

                <div className="bg-slate-800 rounded-xl p-4 print:hidden">
                  <h3 className="font-semibold mb-2">💡 Consello</h3>
                  <p className="text-slate-300 text-sm">
                    {savings.occupancyRate > 0.8
                      ? 'Propiedade con alta ocupación. Considera negociar unha tarifa indexada co teu proveedor para beneficiarte das horas de baixa demanda.'
                      : 'Podes programar os termostatos para pre-quentar durante as horas de baixa demanda (00h-08h) e así reducir o custo total.'}
                  </p>
                </div>
              </div>
            )}
          </section>
        </div>
      )}

      <footer className="mt-16 pt-8 border-t border-slate-800 text-center text-slate-600 text-sm print:hidden">
        EnergyOS MVP v0.1 · Next.js + JSON Storage + Tailwind · OpenClaw 🐙
      </footer>
    </main>
  )
}

