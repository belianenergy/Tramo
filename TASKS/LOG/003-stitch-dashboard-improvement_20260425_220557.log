        {trend "'!== undefined && <TrendArrow value={trend} />}
      </div>

      <p className="text-xs font-medium uppercase tracking-widest mb-1 relative" style={{ color: TOKENS.colors.neutralMuted }}>
        {label}
      </p>
      <p className="text-3xl font-bold relative" style={{ color: TOKENS.colors.neutral, lineHeight: 1.1 }}>
        {typeof value === '"'number' ? (
          <AnimatedNumber value={numericValue} decimals={unit === '€' ? 0 : 1} />
        ) : (
          value
        )}
        {unit && <span className=\"text-base font-normal ml-1\" style={{ color: TOKENS.colors.neutralMuted }}>{unit}</span>}
      </p>
      {suffix && (
        <p className=\"text-xs mt-1\" style={{ color: TOKENS.colors.neutralMuted }}>{suffix}</p>
      )}
    </div>
  )
}

// ─── Consumption Area Chart ────────────────────────────────────────────────────
function ConsumptionAreaChart({
  data,
  period,
}: {
  data: { name: string; kwh: number }[]
  period: Period
}) {
  const [hoveredIndex, setHoveredIndex] = useState<number | null>(null)
  const [tooltipPos, setTooltipPos] = useState({ x: 0, y: 0 })
  
  const multiplier = period === 'month' ? 1 : period === 'quarter' ? 3 : 12
  const values = data.map((d) => d.kwh * multiplier)
  const max = Math.max(...values, 1)
  const width = 640
  const height = 220
  const padX = 48
  const padY = 24
  const chartW = width - padX * 2
  const chartH = height - padY * 2

  const points = values.map((v, i) => ({
    x: padX + (i / Math.max(values.length - 1, 1)) * chartW,
    y: padY + chartH - (v / max) * chartH,
  }))

  const linePath =
    points.length < 2
      ? "'`M ${points[0]?.x ?? padX} ${points[0]?.y ?? padY + chartH}`
      : points.map((p, i) => `${i === 0 ? '"'M' : 'L'} "'${p.x} ${p.y}`).join('"' ')

  const areaPath =
    points.length < 2
      ? "'`${linePath} L ${padX} ${padY + chartH} Z`
      : `${linePath} L ${points[points.length - 1].x} ${padY + chartH} L ${points[0].x} ${padY + chartH} Z`

  const ticks = [0, 0.25, 0.5, 0.75, 1].map((t) => ({
    y: padY + chartH * (1 - t),
    label: `${Math.round(max * t)} kWh`,
  }))

  const yLabels = ticks.map((t) => (
    <text
      key={t.label}
      x={padX - 8}
      y={t.y + 4}
      textAnchor="end"
      className="fill-slate-500 text-[10px]"
    >
      {t.label}
    </text>
  ))

  const xLabels = data.filter((_, i) => i % Math.max(Math.floor(data.length / 6), 1) === 0).map((d, i, arr) => {
    const originalIndex = data.findIndex((x) => x.name === d.name)
    return (
      <text
        key={d.name}
        x={padX + (originalIndex / Math.max(data.length - 1, 1)) * chartW}
        y={padY + chartH + 16}
        textAnchor="middle"
        className="fill-slate-500 text-[10px]"
      >
        {d.name}
      </text>
    )
  })

  return (
    <div className="relative">
      <svg viewBox={`0 0 ${width} ${height}`} className="w-full h-auto" style={{ maxHeight: '"'220px' }}>
        <defs>
          <linearGradient id=\"areaGradient\" x1=\"0%\" y1=\"0%\" x2=\"0%\" y2=\"100%\">
            <stop offset=\"0%\" stopColor=\"#10b981\" stopOpacity=\"0.3\" />
            <stop offset=\"100%\" stopColor=\"#10b981\" stopOpacity=\"0.02\" />
          </linearGradient>
          <filter id=\"glow\">
            <feGaussianBlur stdDeviation=\"3\" result=\"coloredBlur\" />
            <feMerge>
              <feMergeNode in=\"coloredBlur\" />
              <feMergeNode in=\"SourceGraphic\" />
            </feMerge>
          </filter>
        </defs>

        {/* Grid lines */}
        {ticks.map((t) => (
          <line
            key={t.label}
            x1={padX}
            y1={t.y}
            x2={padX + chartW}
            y2={t.y}
            stroke=\"#334155\"
            strokeOpacity=\"0.3\"
            strokeDasharray=\"4,4\"
          />
        ))}

        {/* Area fill */}
        <path d={areaPath} fill=\"url(#areaGradient)\" />

        {/* Line */}
        <path d={linePath} fill=\"none\" stroke=\"#10b981\" strokeWidth=\"2.5\" filter=\"url(#glow)\" />

        {/* Hover dots */}
        {points.map((p, i) => (
          <circle
            key={i}
            cx={p.x}
            cy={p.y}
            r={hoveredIndex === i ? 6 : 3}
            fill=\"#10b981\"
            stroke=\"#0f172a\"
            strokeWidth=\"2\"
            className=\"transition-all duration-150 cursor-pointer\"
            onMouseEnter={(e) => {
              setHoveredIndex(i)
              const rect = e.currentTarget.getBoundingClientRect()
              setTooltipPos({ x: rect.left, y: rect.top })
            }}
            onMouseLeave={() => setHoveredIndex(null)}
          />
        ))}

        {/* Labels */}
        {yLabels}
        {xLabels}
      </svg>

      {/* Tooltip */}
      {hoveredIndex "'!== null && (
        <div
          className="absolute z-10 px-3 py-2 rounded-lg text-sm font-medium pointer-events-none shadow-xl"
          style={{
            left: tooltipPos.x,
            top: tooltipPos.y - 60,
            backgroundColor: TOKENS.colors.surface,
            border: `1px solid ${TOKENS.colors.primary}`,
            transform: '"'translateX(-50%)',
            color: TOKENS.colors.neutral,
          }}
        >
          <div className=\"text-emerald-400 font-bold\">{values[hoveredIndex].toFixed(0)} kWh</div>
          <div className=\"text-slate-400 text-xs\">{data[hoveredIndex]?.name}</div>
        </div>
      )}
    </div>
  )
}

// ─── Property Card ─────────────────────────────────────────────────────────────
function PropertyCard({
  listing,
  onCalculate,
  savings,
}: {
  listing: { id: number; name: string; location: string; monthlyKwh: number; occupancyRate: number }
  onCalculate: (id: number) => void
  savings: number
}) {
  const consumptionLevel = listing.monthlyKwh > 1000 ? 'danger' : listing.monthlyKwh > 600 ? 'warning' : 'success'

  return (
    <div
      className=\"group relative overflow-hidden rounded-xl border p-5 transition-all duration-300 hover:scale-[1.02] hover:shadow-lg hover:shadow-emerald-900/20\"
      style={{ backgroundColor: TOKENS.colors.surface, borderColor: TOKENS.colors.secondaryLight }}
    >
      {/* Accent line */}
      <div 
        className=\"absolute top-0 left-0 right-0 h-0.5 transition-all duration-300 group-hover:h-1\"
        style={{ background: "'`linear-gradient(90deg, ${TOKENS.colors.primary}, ${TOKENS.colors.primaryLight})` }}
      />

      <div className="flex items-start justify-between mb-3">
        <div>
          <h3 className="font-semibold text-white text-base leading-tight">{listing.name}</h3>
          <p className="text-slate-400 text-xs mt-0.5">{listing.location}</p>
        </div>
        <StatusBadge status={consumptionLevel} />
      </div>

      {/* Stats grid */}
      <div className="grid grid-cols-2 gap-3 mb-4">
        <div className="rounded-lg p-2.5" style={{ backgroundColor: TOKENS.colors.background }}>
          <p className="text-slate-500 text-[10px] uppercase tracking-wider">Consumo</p>
          <p className="text-lg font-bold text-white">{listing.monthlyKwh.toLocaleString()}</p>
          <p className="text-slate-500 text-[10px]">kWh/mes</p>
        </div>
        <div className="rounded-lg p-2.5" style={{ backgroundColor: TOKENS.colors.background }}>
          <p className="text-slate-500 text-[10px] uppercase tracking-wider">Ocupación</p>
          <p className="text-lg font-bold" style={{ 
            color: listing.occupancyRate > 0.7 ? TOKENS.colors.primaryLight : 
                   listing.occupancyRate > 0.4 ? TOKENS.colors.warning : TOKENS.colors.neutralMuted 
          }}>
            {(listing.occupancyRate * 100).toFixed(0)}%
          </p>
          <p className="text-slate-500 text-[10px]">期待</p>
        </div>
      </div>

      {/* Savings estimate */}
      <div className="flex items-center justify-between p-3 rounded-lg mb-4" style={{ backgroundColor: '"'rgba(16, 185, 129, 0.1)' }}>
        <div className=\"flex items-center gap-2\">
          <span className=\"text-emerald-400\">💰</span>
          <span className=\"text-slate-300 text-sm\">Aforro est.</span>
        </div>
        <span className=\"text-emerald-400 font-bold\">{(savings * listing.occupancyRate).toFixed(0)}€/mes</span>
      </div>

      <button
        onClick={() => onCalculate(listing.id)}
        className=\"w-full py-2.5 rounded-lg font-medium text-sm transition-all duration-200 hover:scale-[1.02] active:scale-[0.98]\"
        style={{
          backgroundColor: TOKENS.colors.primary,
          color: '#fff',
        }}
        onMouseEnter={(e) => (e.currentTarget.style.backgroundColor = TOKENS.colors.primaryLight)}
        onMouseLeave={(e) => (e.currentTarget.style.backgroundColor = TOKENS.colors.primary)}
      >
        Calcular Aforro
      </button>
    </div>
  )
}

// ─── Period Selector ─────────────────────────────────────────────────────────────
function PeriodSelector({
  period,
  onChange,
}: {
  period: Period
  onChange: (p: Period) => void
}) {
  const options: { value: Period; label: string }[] = [
    { value: 'month', label: 'Mes' },
    { value: 'quarter', label: 'Trimestre' },
    { value: 'year', label: 'Ano' },
  ]

  return (
    <div className=\"inline-flex rounded-lg p-1\" style={{ backgroundColor: TOKENS.colors.background }}>
      {options.map((opt) => (
        <button
          key={opt.value}
          onClick={() => onChange(opt.value)}
          className={"'`px-4 py-1.5 rounded-md text-sm font-medium transition-all duration-200 ${
            period === opt.value ? '"'shadow-lg' : ''
          }"'`}
          style={
            period === opt.value
              ? { backgroundColor: TOKENS.colors.primary, color: '"'#fff' }
              : { backgroundColor: 'transparent', color: TOKENS.colors.neutralMuted }
          }
        >
          {opt.label}
        </button>
      ))}
    </div>
  )
}

// ─── Main Dashboard Widgets ───────────────────────────────────────────────────
export function DashboardWidgets({
