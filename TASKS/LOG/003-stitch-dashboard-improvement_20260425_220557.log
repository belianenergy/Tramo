        { name: 'Mar', kwh: 280 },
        { name: 'Mér', kwh: 350 },
        { name: 'Xov', kwh: 310 },
        { name: 'Ven', kwh: 380 },
        { name: 'Sáb', kwh: 420 },
        { name: 'Dom', kwh: 390 },
      ]

  return (
    <div className=\"space-y-6\">
      {/* ── Header with gradient ── */}
      <div 
        className=\"rounded-xl p-6 border relative overflow-hidden\"
        style={{ 
