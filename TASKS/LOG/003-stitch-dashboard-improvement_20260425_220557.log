'use client'

import { useState, useEffect, useRef } from 'react'

type Period = 'month' | 'quarter' | 'year'

// ─── Design Tokens (from DESIGN.md) ─────────────────────────────────────────
const TOKENS = {
  colors: {
    primary: '#059669',
    primaryLight: '#10b981',
    primaryDark: '#047857',
    secondary: '#1e293b',
    secondaryLight: '#334155',
    neutral: '#f8fafc',
    neutralMuted: '#94a3b8',
    danger: '#ef4444',
    dangerLight: '#fca5a5',
    warning: '#f59e0b',
    warningLight: '#fbbf24',
    background: '#0f172a',
    surface: '#1e293b',
  },
  spacing: { xs: '0.25rem', sm: '0.5rem', md: '1rem', lg: '1.5rem', xl: '2rem', '2xl': '3rem' },
  rounded: { sm: '0.25rem', md: '0.5rem', lg: '0.75rem', xl: '1rem', full: '9999px' },
}

// ─── Animated Counter ───────────────────────────────────────────────────────
function AnimatedNumber({ value, decimals = 0 }: { value: number; decimals?: number }) {
  const [display, setDisplay] = useState(0)
  const prevValue = useRef(value)

  useEffect(() => {
    const diff = value - prevValue.current
    if (Math.abs(diff) < 0.01) {
      setDisplay(value)
      return
    }
    
    const steps = 30
    const increment = diff / steps
    let current = prevValue.current
    let step = 0
    
    const timer = setInterval(() => {
      step++
      current += increment
      if (step >= steps) {
        setDisplay(value)
        clearInterval(timer)
      } else {
        setDisplay(current)
      }
    }, 20)
    
    prevValue.current = value
    return () => clearInterval(timer)
  }, [value])

  return <>{decimals > 0 ? display.toFixed(decimals) : Math.round(display).toLocaleString()}</>
}

// ─── Trend Arrow ─────────────────────────────────────────────────────────────
function TrendArrow({ value }: { value: number }) {
  if (value === 0) return <span className=\"text-slate-500 text-sm\">—</span>
  const up = value > 0
  return (
    <span className={"'`flex items-center gap-0.5 text-xs font-medium ${up ? '"'text-red-400' : 'text-emerald-400'}"'`}>
      {up ? '"'↑' : '↓'} {Math.abs(value).toFixed(1)}%
    </span>
  )
}

