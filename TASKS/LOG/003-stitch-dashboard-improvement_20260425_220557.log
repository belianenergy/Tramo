                <p className=\"text-lg font-bold text-red-400\">
                  {dashboard.totalCostBefore.toFixed(0)}
                  <span className=\"text-xs text-slate-500 ml-1\">€/mes</span>
                </p>
              </div>
              <div className=\"rounded-lg p-3 text-center transition-all duration-200 hover:bg-slate-700/50\" style={{ backgroundColor: '#0f172a' }}>
                <p className=\"text-slate-500 text-xs mb-1\">Custo optim.</p>
                <p className=\"text-lg font-bold text-emerald-400\">
