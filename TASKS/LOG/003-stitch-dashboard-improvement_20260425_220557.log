          <section className="bg-slate-800 rounded-xl overflow-hidden">
            <div className="overflow-x-auto">
              <table className="w-full">
                <thead className="bg-slate-700 text-slate-300 text-sm">
                  <tr>
                    <th className="py-3 px-4 text-left font-medium">Nome</th>
                    <th className="py-3 px-4 text-left font-medium">Localización</th>
                    <th className="py-3 px-4 text-left font-medium">Consumo</th>
                    <th className="py-3 px-4 text-left font-medium">Ocupación</th>
                    <th className="py-3 px-4 text-left font-medium">Acccións</th>
                  </tr>
                </thead>
                <tbody className="divide-y divide-slate-700">
                  {listings.map(listing => (
                    <tr key={listing.id} className="hover:bg-slate-700/50 transition">
                      <td className="py-3 px-4">
                        <span className="text-white font-medium">{listing.name}</span>
                        {listing.monthlyKwh > 1000 && <span className="ml-2 text-amber-400">⚡</span>}
                      </td>
                      <td className="py-3 px-4 text-slate-400 text-sm">{listing.location}</td>
                      <td className="py-3 px-4">
                        <span className={`font-medium ${listing.monthlyKwh > 1000 ? 'text-amber-400' : 'text-emerald-400'}`}>
                          {listing.monthlyKwh} kWh
                        </span>
                      </td>
                      <td className="py-3 px-4 text-blue-400">{(listing.occupancyRate * 100).toFixed(0)}%</td>
                      <td className="py-3 px-4">
                        <button onClick={() => calculateSavingsForListing(listing.id)}
