          borderColor: TOKENS.colors.secondaryLight,
        }}
      >
        <div className=\"flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-5\">
          <div>
            <h2 className=\"text-lg font-semibold text-white\">Propiedades</h2>
            <p className=\"text-slate-400 text-sm mt-0.5\">
              {listings.length} propiedades rexistradas
            </p>
          </div>
          
          {/* Quick filter badges */}
          <div className=\"flex gap-2\">
            <span className=\"inline-flex items-center px-2 py-1 rounded-full text-xs\" style={{ backgroundColor: TOKENS.colors.primary, color: '#fff' }}>
              {listings.filter(l => l.monthlyKwh <= 600).length} Normais
            </span>
            <span className=\"inline-flex items-center px-2 py-1 rounded-full text-xs\" style={{ backgroundColor: TOKENS.colors.warning, color: '#000' }}>
              {listings.filter(l => l.monthlyKwh > 600 && l.monthlyKwh <= 1000).length} Altas
            </span>
            <span className=\"inline-flex items-center px-2 py-1 rounded-full text-xs\" style={{ backgroundColor: TOKENS.colors.danger, color: '#fff' }}>
              {listings.filter(l => l.monthlyKwh > 1000).length} Alertas
            </span>
          </div>
        </div>

        {listings.length > 0 ? (
          <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4\">
            {listings.map((listing) => (
              <PropertyCard
                key={listing.id}
                listing={listing}
                onCalculate={onCalculate}
                savings={dashboard.totalSavingsMonthly / Math.max(dashboard.totalListings, 1)}
              />
            ))}
          </div>
        ) : (
          <div className=\"flex flex-col items-center justify-center py-12 text-center\">
            <span className=\"text-5xl mb-4\">🏠</span>
            <p className=\"text-slate-400 mb-2 text-lg\">Aínda non hai propiedades</p>
            <p className=\"text-slate-500 text-sm\">Engade a primeira propiedade na pestana Propiedades</p>
          </div>
        )}
      </section>
    </div>
  )
}
