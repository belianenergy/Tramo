              Resumo do consumo enerxético das túas propiedades
            </p>
          </div>
          <PeriodSelector period={period} onChange={setPeriod} />
        </div>
      </div>

      {/* ── Metric cards ── */}
      <div className=\"grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4\">
        <MetricCard
          label=\"Consumo Total\"
          value={dashboard.totalKwh}
          unit=\"kWh\"
          icon=\"⚡\"
          color=\"#10b981\"
          trend={-5.2}
          suffix={"'`${period === '"'month' ? 'este mes' : period === 'quarter' ? 'este trim.' : 'este ano'}"'`}
        />
        <MetricCard
          label="Aforro Mensual"
          value={dashboard.totalSavingsMonthly}
          unit="€"
          icon="💰"
          color="#10b981"
          trend={-12.5}
